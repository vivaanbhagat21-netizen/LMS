# Edugen Environment Variables

# Google OAuth 2.0 Credentials
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth callback URL (must match Google Cloud Console authorized redirect URI)
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session secret (change this to a random string in production)
SESSION_SECRET=edugen-super-secret-key-change-me

# Server port
PORT=3000
